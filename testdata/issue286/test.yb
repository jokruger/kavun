#!/usr/bin/env gs
// This test should pass if the interpreter's gs.Compiler.SetImportExt() was set as `c.SetImportExt(".gs", ".yb")`.

os := import("os")
uno := import("uno") // it will search uno.gs and uno.yb
fmt := import("fmt")
text := import("text")

expected := ["test", "uno", "dos", "tres", "quatro", "cinco"]
expected = text.join(expected, " ")
if v := uno.fn("test"); v != expected {
    fmt.printf("relative import test error:\n\texpected: %v\n\tgot     : %v\n",
                expected, v)
    os.exit(1)
}

args := text.join(os.args(), " ")
fmt.println("ok\t", args)
